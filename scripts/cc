#!/usr/bin/env bash
# ==============================================================================
# cc — Claude Code instance manager for Tmux
#
# Usage:
#   cc [name] [workdir]    Launch Claude Code in a named Tmux window
#   cc -l                  List all windows in the current session
#   cc -a                  List windows with 🔔 (needs attention)
#   cc -g <name>           Go to (jump to) a window by name (fuzzy match)
#   cc -x <name>           Close a window by name (fuzzy match)
#   cc                     Launch with default name "claude"
#
# Examples:
#   cc auth                → new window "auth" running claude
#   cc payment ~/pay       → new window "payment" in ~/pay directory
#   cc -g auth             → jump to the "auth" window
# ==============================================================================

set -uo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

die() { echo -e "${RED}[!]${NC} $*" >&2; exit 1; }

# Must be inside Tmux
[[ -z "${TMUX:-}" ]] && die "Not inside Tmux. Run 'work' first to start a session."

# ── Subcommands ─────────────────────────────────────────────────────────────

# List all windows
list_windows() {
  echo -e "${BOLD}Windows in session:${NC}"
  tmux list-windows -F "  #{?window_active,${GREEN}▸${NC},${DIM} ${NC}} #I: #{window_name}  ${DIM}#{pane_current_path}${NC}" 2>/dev/null
}

# List windows needing attention (🔔)
list_alerts() {
  local bells
  bells=$(tmux list-windows -F '#{window_index}:#{window_name}' 2>/dev/null | grep '🔔' || true)
  if [[ -z "$bells" ]]; then
    echo -e "${GREEN}No windows need attention.${NC}"
  else
    echo -e "${YELLOW}${BOLD}Windows needing attention:${NC}"
    echo "$bells" | while IFS= read -r line; do
      echo -e "  ${YELLOW}🔔${NC} $line"
    done
  fi
}

# Find window by fuzzy name match → prints window index or empty
find_window() {
  local pattern="$1"
  # Exact match first (ignoring 🔔 prefix)
  local match
  match=$(tmux list-windows -F '#{window_index}:#{window_name}' 2>/dev/null \
    | sed 's/🔔//' | grep -i "^[0-9]*:${pattern}$" | head -1 | cut -d: -f1)
  if [[ -n "$match" ]]; then
    echo "$match"
    return
  fi
  # Substring match
  match=$(tmux list-windows -F '#{window_index}:#{window_name}' 2>/dev/null \
    | sed 's/🔔//' | grep -i "${pattern}" | head -1 | cut -d: -f1)
  echo "$match"
}

# Go to window
goto_window() {
  local name="$1"
  local idx
  idx=$(find_window "$name")
  if [[ -z "$idx" ]]; then
    die "No window matching '$name'. Use 'cc -l' to list."
  fi
  tmux select-window -t ":$idx"
}

# Close window
close_window() {
  local name="$1"
  local idx
  idx=$(find_window "$name")
  if [[ -z "$idx" ]]; then
    die "No window matching '$name'. Use 'cc -l' to list."
  fi
  local wname
  wname=$(tmux list-windows -F '#{window_index}:#{window_name}' | grep "^${idx}:" | cut -d: -f2-)
  tmux kill-window -t ":$idx"
  echo -e "${GREEN}Closed window ${idx}: ${wname}${NC}"
}

# ── Parse arguments ─────────────────────────────────────────────────────────

case "${1:-}" in
  -l) list_windows; exit 0 ;;
  -a) list_alerts;  exit 0 ;;
  -g)
    [[ -z "${2:-}" ]] && die "Usage: cc -g <name>"
    goto_window "$2"; exit 0
    ;;
  -x)
    [[ -z "${2:-}" ]] && die "Usage: cc -x <name>"
    close_window "$2"; exit 0
    ;;
  -h|--help)
    echo "Usage: cc [name] [workdir] | cc -l | cc -a | cc -g <name> | cc -x <name>"
    exit 0
    ;;
esac

# ── Launch Claude Code in a new window ──────────────────────────────────────

name="${1:-claude}"
workdir="${2:-}"

# Resolve workdir
if [[ -n "$workdir" ]]; then
  workdir=$(cd "$workdir" 2>/dev/null && pwd || echo "$workdir")
fi

# If window with this name already exists, jump to it
existing=$(find_window "$name")
if [[ -n "$existing" ]]; then
  echo -e "${YELLOW}Window '$name' already exists — switching to it.${NC}"
  tmux select-window -t ":$existing"
  exit 0
fi

# Create new window
if [[ -n "$workdir" ]]; then
  tmux new-window -n "$name" -c "$workdir" "claude"
else
  tmux new-window -n "$name" "claude"
fi
