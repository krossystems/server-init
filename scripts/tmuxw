#!/usr/bin/env bash
# ==============================================================================
# tmuxw — Tmux window manager
#
# Usage:
#   tmuxw [name] [workdir]   Create a named window (or jump to it if exists)
#   tmuxw -l                 List windows with detailed info and status markers
#   tmuxw -a                 List all windows including parked, in table format
#   tmuxw -x <name>          Close a window by name (fuzzy match)
#   tmuxw -p [name]          Park a window (default: current) to park-<session>
#   tmuxw -u <name>          Unpark a window back to current session
#   tmuxw                    Create window named "shell"
#
# Park sessions are per-session: session "main" parks to "park-main".
# ==============================================================================

set -uo pipefail

RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'
CYAN=$'\033[0;36m'; BOLD=$'\033[1m'; DIM=$'\033[2m'; NC=$'\033[0m'

die() { echo -e "${RED}[!]${NC} $*" >&2; exit 1; }

# Must be inside Tmux
[[ -z "${TMUX:-}" ]] && die "Not inside Tmux. Run 'tmuxs' first to start a session."

CUR_SESSION=$(tmux display-message -p '#{session_name}' 2>/dev/null)
PARK_SESSION="park-${CUR_SESSION}"

# ── Helpers ───────────────────────────────────────────────────────────────────

# Strip status markers from window name
strip_markers() {
  local n="$1"
  n="${n#⏳}"; n="${n#⌛}"; n="${n#🟢}"; n="${n#🔔}"
  echo "$n"
}

# Extract marker from window name (if any)
get_marker() {
  local n="$1"
  case "$n" in
    ⏳*) echo "⏳" ;;
    ⌛*) echo "⌛" ;;
    🟢*) echo "🟢" ;;
    🔔*) echo "🔔" ;;
    *)    echo "—"  ;;
  esac
}

# Shorten path: replace $HOME with ~
short_path() {
  echo "${1/#$HOME/~}"
}

# Find window by fuzzy name match → prints window index or empty
# Usage: find_window <pattern> [session]
find_window() {
  local pattern="$1"
  local session="${2:-}"
  local target_flag=""
  [[ -n "$session" ]] && target_flag="-t $session"

  # Exact match first (ignoring status markers)
  local match
  match=$(tmux list-windows $target_flag -F '#{window_index}:#{window_name}' 2>/dev/null \
    | sed 's/[🟢🔔⏳⌛]//' | grep -i "^[0-9]*:${pattern}$" | head -1 | cut -d: -f1)
  if [[ -n "$match" ]]; then
    echo "$match"
    return
  fi
  # Substring match
  match=$(tmux list-windows $target_flag -F '#{window_index}:#{window_name}' 2>/dev/null \
    | sed 's/[🟢🔔⏳⌛]//' | grep -i "${pattern}" | head -1 | cut -d: -f1)
  echo "$match"
}

# ── Subcommands ───────────────────────────────────────────────────────────────

# List windows in current session with detailed table
list_windows() {
  echo -e "${BOLD}Windows in \"${CUR_SESSION}\":${NC}"
  printf "  ${DIM}%-4s %-20s %-8s %s${NC}\n" "#" "Name" "Status" "Path"
  printf "  ${DIM}%-4s %-20s %-8s %s${NC}\n" "──" "────────────────────" "──────" "────────────────"

  tmux list-windows -F '#{window_index}|#{window_name}|#{window_active}|#{pane_current_path}' 2>/dev/null \
  | while IFS='|' read -r idx wname active path; do
    local clean marker color
    clean=$(strip_markers "$wname")
    marker=$(get_marker "$wname")
    path=$(short_path "$path")

    if [[ "$active" == "1" ]]; then
      color="$GREEN"
      [[ "$marker" == "—" ]] && marker="▸"
    else
      color="$NC"
    fi

    printf "  ${color}%-4s %-20s %-8s %s${NC}\n" "$idx" "$clean" "$marker" "$path"
  done
}

# List ALL windows: current session + parked, in table format
list_all() {
  # Current session
  list_windows

  # Parked windows
  if tmux has-session -t "$PARK_SESSION" 2>/dev/null; then
    local parked
    parked=$(tmux list-windows -t "$PARK_SESSION" -F '#{window_index}|#{window_name}|#{pane_current_path}' 2>/dev/null || true)
    if [[ -n "$parked" ]]; then
      echo
      echo -e "${BOLD}Parked (${PARK_SESSION}):${NC}"
      printf "  ${DIM}%-4s %-20s %-8s %s${NC}\n" "#" "Name" "Status" "Path"
      printf "  ${DIM}%-4s %-20s %-8s %s${NC}\n" "──" "────────────────────" "──────" "────────────────"

      echo "$parked" | while IFS='|' read -r idx wname path; do
        local clean marker
        clean=$(strip_markers "$wname")
        marker=$(get_marker "$wname")
        path=$(short_path "$path")
        [[ "$marker" == "—" ]] && marker="P"
        printf "  ${DIM}%-4s %-20s %-8s %s${NC}\n" "$idx" "$clean" "$marker" "$path"
      done
    fi
  else
    echo
    echo -e "${DIM}No parked windows.${NC}"
  fi
}

# Close window
close_window() {
  local name="$1"
  local idx
  idx=$(find_window "$name")
  if [[ -z "$idx" ]]; then
    die "No window matching '$name'. Use 'tmuxw -l' to list."
  fi
  local wname
  wname=$(tmux list-windows -F '#{window_index}:#{window_name}' | grep "^${idx}:" | cut -d: -f2-)
  tmux kill-window -t ":$idx"
  echo -e "${GREEN}Closed window ${idx}: ${wname}${NC}"
}

# Park a window — move to per-session park
park_window() {
  local name="${1:-}"

  # Ensure park session exists
  if ! tmux has-session -t "$PARK_SESSION" 2>/dev/null; then
    tmux new-session -d -s "$PARK_SESSION"
  fi

  # Don't park the last window
  local win_count
  win_count=$(tmux list-windows 2>/dev/null | wc -l)
  if (( win_count <= 1 )); then
    die "Can't park the only window. Create another window first."
  fi

  if [[ -z "$name" ]]; then
    # Park current window
    local cur_name
    cur_name=$(tmux display-message -p '#{window_name}' 2>/dev/null)
    tmux move-window -t "$PARK_SESSION"
    echo -e "${GREEN}Parked '$(strip_markers "$cur_name")' → ${PARK_SESSION}${NC}"
  else
    local idx
    idx=$(find_window "$name")
    if [[ -z "$idx" ]]; then
      die "No window matching '$name'. Use 'tmuxw -l' to list."
    fi
    local wname
    wname=$(tmux list-windows -F '#{window_index}:#{window_name}' | grep "^${idx}:" | cut -d: -f2-)
    tmux move-window -s ":$idx" -t "$PARK_SESSION"
    echo -e "${GREEN}Parked '$(strip_markers "$wname")' → ${PARK_SESSION}${NC}"
  fi
}

# Unpark a window — move from park session back here
unpark_window() {
  local name="$1"

  if ! tmux has-session -t "$PARK_SESSION" 2>/dev/null; then
    die "No parked windows (${PARK_SESSION} doesn't exist)."
  fi

  local idx
  idx=$(find_window "$name" "$PARK_SESSION")
  if [[ -z "$idx" ]]; then
    die "No parked window matching '$name'. Use 'tmuxw -a' to list."
  fi
  local wname
  wname=$(tmux list-windows -t "$PARK_SESSION" -F '#{window_index}:#{window_name}' \
    | grep "^${idx}:" | cut -d: -f2-)

  tmux move-window -s "${PARK_SESSION}:${idx}" -t "$CUR_SESSION"
  echo -e "${GREEN}Unparked '$(strip_markers "$wname")' → ${CUR_SESSION}${NC}"

  # Clean up park session if empty
  local remaining
  remaining=$(tmux list-windows -t "$PARK_SESSION" 2>/dev/null | wc -l || echo 0)
  if (( remaining == 0 )); then
    tmux kill-session -t "$PARK_SESSION" 2>/dev/null || true
  fi
}

# ── Parse arguments ───────────────────────────────────────────────────────────

case "${1:-}" in
  -l) list_windows; exit 0 ;;
  -a) list_all;     exit 0 ;;
  -x)
    [[ -z "${2:-}" ]] && die "Usage: tmuxw -x <name>"
    close_window "$2"; exit 0
    ;;
  -p) park_window "${2:-}"; exit 0 ;;
  -u)
    [[ -z "${2:-}" ]] && die "Usage: tmuxw -u <name>  (use 'tmuxw -a' to see parked windows)"
    unpark_window "$2"; exit 0
    ;;
  -h|--help)
    cat <<'EOF'
Usage:
  tmuxw [name] [workdir]   Create/jump to a named window
  tmuxw -l                 List windows with status markers (table)
  tmuxw -a                 List all windows including parked (table)
  tmuxw -x <name>          Close window (fuzzy match)
  tmuxw -p [name]          Park window (default: current)
  tmuxw -u <name>          Unpark window by name
EOF
    exit 0
    ;;
esac

# ── Create a new window ──────────────────────────────────────────────────────

name="${1:-shell}"
workdir="${2:-}"

# Resolve workdir
if [[ -n "$workdir" ]]; then
  workdir=$(cd "$workdir" 2>/dev/null && pwd || echo "$workdir")
fi

# If window with this name already exists, jump to it
existing=$(find_window "$name")
if [[ -n "$existing" ]]; then
  echo -e "${YELLOW}Window '$name' already exists — switching to it.${NC}"
  tmux select-window -t ":$existing"
  exit 0
fi

# Create new window (plain shell, user starts whatever they need)
if [[ -n "$workdir" ]]; then
  tmux new-window -n "$name" -c "$workdir"
else
  tmux new-window -n "$name"
fi
